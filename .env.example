# Copy to .env for local testing (do NOT commit the real .env file).
# For GitHub Actions, set REC_EMAIL / REC_PASSWORD as repo Secrets, and the
# rest as repo Variables (Settings > Secrets and variables > Actions).

REC_EMAIL=you@example.com
REC_PASSWORD=your-password-here

CLASS_NAME=Total Resistance
TARGET_WEEKDAY=Tuesday
TARGET_TIME=08:00

# Optional — only needed if your account has more than one family member
# or more than one eligible membership for this class.
PARTICIPANT_NAME=
MEMBERSHIP_NAME=

# "true" to stop right before the final confirm click, for safe testing.
DRY_RUN=true

MAX_WAIT_MINUTES=10
